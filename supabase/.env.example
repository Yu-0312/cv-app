# Supabase Edge Functions environment variables
# Copy this file to supabase/.env and fill in your values
# Never commit the real .env file

# Required — from Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Required for Edge Function: career-ops-extract-profile (LLM resume parsing)
ANTHROPIC_API_KEY=sk-ant-...

# Optional — used for the share link in career-ops-share-analysis
SITE_URL=https://your-username.github.io/your-repo

# Required for the SaaS worker (career-ops-saas-worker.mjs)
# Same as above — set these in your shell or Railway/Fly.io environment
# SUPABASE_URL=...
# SUPABASE_SERVICE_ROLE_KEY=...
