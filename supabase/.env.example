# Supabase Edge Functions environment variables
# Copy this file to supabase/.env and fill in your values
# Never commit the real .env file

# Required — from Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional — used for the share link in career-ops-share-analysis
SITE_URL=https://your-username.github.io/your-repo

# Optional advanced queue worker (career-ops-saas-worker.mjs)
# The hosted BYOK browser analysis does not need Railway/Fly.io.
# If you enable queue mode, set these in your shell or worker environment.
# SUPABASE_URL=...
# SUPABASE_SERVICE_ROLE_KEY=...

# No ANTHROPIC_API_KEY / OPENAI_API_KEY is needed for hosted user analysis.
# Users provide their own AI key in the browser; it is not stored in Supabase.
